{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "claude-security@claude-plugins-official": true
  },
  "effortLevel": "high",
  "model": "claude-fable-5[1m]",
  "permissions": {
    "deny": [
      "CronCreate",
      "CronList",
      "CronDelete",
      "RemoteTrigger",
      "NotebookEdit",
      "DesignSync",
      "SendMessage",
      "PushNotification",
      "ShareOnboardingGuide"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/statusline-command.sh\""
  },
  "feedbackSurveyRate": 0,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85"
  },
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "autoDreamEnabled": false,
  "disableWorkflows": true,
  "disableArtifact": true,
  "includeGitInstructions": false,
  "skillOverrides": {
    "deep-research": "user-invocable-only",
    "dataviz": "off",
    "artifact-design": "off",
    "artifact-capabilities": "off",
    "keybindings-help": "user-invocable-only",
    "simplify": "user-invocable-only",
    "fewer-permission-prompts": "user-invocable-only",
    "loop": "user-invocable-only",
    "schedule": "off",
    "claude-api": "user-invocable-only",
    "run": "user-invocable-only",
    "init": "user-invocable-only",
    "review": "user-invocable-only",
    "security-review": "user-invocable-only"
  }
}
